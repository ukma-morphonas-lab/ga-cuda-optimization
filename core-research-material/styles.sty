\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{gapaper}[2026/01/08 GA Paper Styles]

%------------ Core packages ------------
\RequirePackage[utf8]{inputenc}
\RequirePackage[english]{babel}
\RequirePackage{geometry}
\RequirePackage{setspace}
\RequirePackage{enumitem}
\RequirePackage{booktabs}
\RequirePackage{float}
\RequirePackage{fancyhdr}
\RequirePackage{hyperref}
\RequirePackage{amsmath}
\RequirePackage[table]{xcolor} 

%------------ Page layout ------------
\geometry{
    left=25mm,
    right=15mm,
    top=20mm,
    bottom=20mm
}

%------------ Line spacing ------------
\setstretch{1.5}

%------------ Header / footer ------------
\pagestyle{fancy}
\fancyhf{}
\fancyhead[R]{\thepage}
\renewcommand{\headrulewidth}{0pt}

%------------ Sectioning helpers ------------
\newcommand{\litSubsubsection}[1]{%
  \subsubsection*{#1}%
}

%------------ Typographical helpers ------------
\newcommand{\parahead}[1]{\textbf{#1}}
\newcommand{\gaop}[1]{\textbf{#1}}

\setlist[itemize]{leftmargin=2em,label=\textbullet,topsep=2pt,itemsep=2pt}

%------------ Math helpers ------------
\newcommand{\vect}[1]{\mathbf{#1}}

%------------ Bibliography (biblatex) ------------
\RequirePackage[backend=biber,style=numeric]{biblatex}

% Default bib file name – can be overridden in main document
\newcommand{\gabibfile}{sources.bib}

\AtBeginDocument{%
  \addbibresource{\gabibfile}%
}

%------------ Figures / images ------------
\RequirePackage{graphicx}
\RequirePackage{subcaption} % for subfigure environments
\RequirePackage{caption}

% Global caption style
\captionsetup{
    font=small,
    labelfont=bf,
    labelsep=colon,
    justification=centering
}

% Convenience env for full-width figure
\newenvironment{gafigure}[1][]%
{%
  \begin{figure}[H]
  \centering
  \captionsetup{justification=centering}
}%
{%
  \end{figure}
}

% Convenience env for two side-by-side subfigures
\newenvironment{gatwofig}[2][]%
{%
  \begin{figure}[H]
  \centering
}%
{%
  \end{figure}
}

% Shorthand macros for including graphics with consistent width
\newcommand{\gaimgfull}[2][]{%
  \includegraphics[width=0.8\textwidth,#1]{#2}%
}

\newcommand{\gaimgsub}[2][]{%
  \includegraphics[width=\textwidth,#1]{#2}%
}