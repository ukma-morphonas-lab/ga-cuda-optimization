@startuml cuda_memory_hierarchy
skinparam monochrome true
skinparam backgroundColor white
skinparam defaultFontName "Serif"
skinparam defaultFontSize 13
skinparam shadowing false

skinparam rectangle {
  BorderColor black
  BackgroundColor white
  FontStyle bold
}

top to bottom direction

' ========= PER-THREAD LEVEL =========
rectangle "**Per-Thread Scope** (private)" as threadlevel {
  rectangle "Thread 0\nRegisters + Local Memory" as t0
  rectangle "Thread 1\nRegisters + Local Memory" as t1
  rectangle "  ...  " as tdots
  rectangle "Thread N\nRegisters + Local Memory" as tN
}

' ========= PER-BLOCK LEVEL =========
rectangle "**Per-Block Scope** (visible to all threads in block)" as blocklevel {
  rectangle "Shared Memory\n//~20-40 cycle latency,  up to 96 KB per SM//" as smem #EEEEEE
}

' ========= DEVICE-WIDE LEVEL =========
rectangle "**Per-Application Scope** (persistent across kernel launches)" as devicelevel {
  rectangle "**Global Memory**\n//read/write, all threads, ~400-800 cycle latency//" as global #DDDDDD
  rectangle "**Constant Memory**\n//read-only, broadcast-optimised//" as constant #DDDDDD
  rectangle "**Texture Memory**\n//read-only, spatially cached//" as texture #DDDDDD
}

' ========= HOST =========
rectangle "**Host (CPU) Memory**" as host

' ── Horizontal layout within levels ──
t0 -[hidden]right- t1
t1 -[hidden]right- tdots
tdots -[hidden]right- tN
global -[hidden]right- constant
constant -[hidden]right- texture

' ── Vertical flow ──
threadlevel -down-> blocklevel : threads access\nshared memory
blocklevel -down-> devicelevel : blocks access\nglobal memory
devicelevel -down-> host : host-device transfer\n(PCIe bus)

@enduml
