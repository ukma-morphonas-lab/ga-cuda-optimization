@startuml ga-lifecycle
skinparam backgroundColor white
skinparam defaultFontSize 13
skinparam defaultFontName "Serif"
skinparam monochrome true
skinparam activity {
  BorderColor black
  BackgroundColor white
  FontSize 13
  ArrowColor black
  DiamondBorderColor black
  DiamondBackgroundColor white
}
skinparam note {
  BackgroundColor white
  BorderColor black
}

title GA Generational Loop

start

:Initialize random population;

repeat

  :**Fitness Evaluation**\nCompute f(x) for each individual\n//Embarrassingly parallel//\n//— main GPU target//;

  :__Selection__\nChoose parents by fitness;

  :__Crossover__\nCombine parent chromosomes;

  :__Mutation__\nIntroduce random changes;

  :Replace population\nwith offspring;

repeat while (Termination criterion met?) is (No)
->Yes;

:Return best solution;

stop

@enduml
