@startuml warp-divergence
!theme plain
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam defaultFontSize 10

title Warp Divergence in SIMT Execution

rectangle "Warp (32 threads)" as warp #LightBlue {
    rectangle "Threads 0-15\n(condition TRUE)" as t_true #LightGreen
    rectangle "Threads 16-31\n(condition FALSE)" as t_false #LightCoral
}

rectangle "Code with Branch" as code #White {
    note as codeblock
        if (threadIdx.x < 16) {
            // Path A
            result = compute_A();
        } else {
            // Path B
            result = compute_B();
        }
    end note
}

rectangle "SIMT Execution Timeline" as timeline #LightYellow {

    rectangle "Step 1: Evaluate Condition" as step1 #White {
        rectangle "All 32 threads" as s1_all #LightBlue
    }

    rectangle "Step 2: Execute Path A" as step2 #White {
        rectangle "T0-T15\nACTIVE" as s2_active #LightGreen
        rectangle "T16-T31\nIDLE" as s2_idle #LightGray
    }

    rectangle "Step 3: Execute Path B" as step3 #White {
        rectangle "T0-T15\nIDLE" as s3_idle #LightGray
        rectangle "T16-T31\nACTIVE" as s3_active #LightCoral
    }

    rectangle "Step 4: Reconverge" as step4 #White {
        rectangle "All 32 threads" as s4_all #LightBlue
    }
}

note right of timeline
  **Performance Impact:**
  - Both paths executed serially
  - Idle threads waste cycles
  - 50% efficiency in this example

  **Mitigation:**
  - Minimize divergent branches
  - Ensure uniform control flow
  - Fitness kernels: same ops for all
end note

code -down-> warp
warp -down-> timeline

step1 -down-> step2
step2 -down-> step3
step3 -down-> step4

@enduml
