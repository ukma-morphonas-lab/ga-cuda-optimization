@startuml gpu-ga-bottlenecks
skinparam backgroundColor white
skinparam defaultFontSize 13
skinparam defaultFontName "Serif"
skinparam monochrome false
skinparam shadowing false
skinparam sequence {
  ArrowColor black
  LifeLineBorderColor black
  LifeLineBackgroundColor white
  ParticipantBorderColor black
  ParticipantBackgroundColor white
  ParticipantFontSize 13
  ParticipantFontStyle bold
  DividerBackgroundColor white
  DividerBorderColor black
  DividerFontStyle bold
  GroupBorderColor black
  GroupBackgroundColor white
  NoteBackgroundColor white
  NoteBorderColor black
}
skinparam BoxPadding 15
skinparam BoxBackgroundColor white
skinparam BoxBorderColor black
skinparam NoteBackgroundColor white
skinparam NoteBorderColor black
skinparam NoteFontColor black

box "Host (CPU)"
  participant "CPU\nOrchestration" as CPU
end box

box "PCIe Bus"
  participant "Data\nTransfer" as PCIE
end box

box "Device (GPU)"
  participant "CUDA\nKernels" as GPU
end box

== Initialization ==

CPU -> PCIE : Transfer population\n& problem data
note left of CPU : Setup cost:\nallocation + copy
activate PCIE
PCIE -> GPU : H2D transfer
note right of GPU : Bottleneck 1:\nPCIe latency\n(~12 GB/s pinned)
activate GPU
deactivate GPU
deactivate PCIE

== Per-Generation Loop ==

CPU -> GPU : Kernel launch
note left of CPU : Bottleneck 2:\nLaunch overhead\n(~5-20 μs per kernel)
activate GPU

GPU -> GPU : Fitness evaluation\n(parallel: N threads)
note right of GPU : Main computation.\nIdle SMs if N is small\n(Bottleneck 3)

GPU -> PCIE : Fitnesses (D2H)
deactivate GPU
activate PCIE
PCIE -> CPU : Small vector (N floats)
deactivate PCIE

CPU -> CPU : Selection (argsort)
note left of CPU : Bottleneck 4:\nSequential CPU work\n(Amdahl's Law limit)
activate CPU
deactivate CPU

CPU -> PCIE : Sorted indices (H2D)
activate PCIE
PCIE -> GPU : Small vector (N ints)
deactivate PCIE

CPU -> GPU : Kernel launch
activate GPU
GPU -> GPU : Crossover + Mutation\n(parallel: GPU RNG)
deactivate GPU

== Finalization ==

GPU -> PCIE : Best solution (D2H)
activate PCIE
PCIE -> CPU : Final result
deactivate PCIE

@enduml
